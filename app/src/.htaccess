<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Allow direct access to public files
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^.*$ - [L]
    
    # Route everything else to index.php
    RewriteRule ^(.*)$ /index.php [L,QSA]
</IfModule>
